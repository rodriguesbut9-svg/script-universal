-- SISTEMA DE ESP UNIVERSAL
---
local function createESP(player)
	if ESP_Cache[player] then return end
	local Box = Drawing.new("Square")
	Box.Color = Color3.fromRGB(255, 0, 0)
	Box.Thickness = 1
	Box.Filled = false
	Box.Visible = false
	
	local Tracer = Drawing.new("Line")
	Tracer.Color = Color3.fromRGB(255, 255, 255)
	Tracer.Thickness = 1
	Tracer.Visible = false
	
	ESP_Cache[player] = {Box = Box, Tracer = Tracer}
end

local function removeESP(player)
	if ESP_Cache[player] then
		ESP_Cache[player].Box:Remove()
		ESP_Cache[player].Tracer:Remove()
		ESP_Cache[player] = nil
	end
end

Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)
for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then createESP(p) end end

local function updateESP()
	for player, v in pairs(ESP_Cache) do
		if ESPEnabled and UI_Visible and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChildOfClass("Humanoid") and player.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
			local hrp = player.Character.HumanoidRootPart
			local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
			
			if onScreen then
				local sizeX = 1000 / screenPos.Z
				local sizeY = 1500 / screenPos.Z
				v.Box.Size = Vector2.new(sizeX, sizeY)
				v.Box.Position = Vector2.new(screenPos.X - sizeX / 2, screenPos.Y - sizeY / 2)
				v.Box.Visible = true
				
				v.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
				v.Tracer.To = Vector2.new(screenPos.X, screenPos.Y)
				v.Tracer.Visible = true
				
				if CurrentTarget == player then
					v.Box.Color = Color3.fromRGB(0, 162, 255)
					v.Tracer.Color = Color3.fromRGB(0, 162, 255)
				else
					v.Box.Color = Color3.fromRGB(255, 50, 50)
					v.Tracer.Color = Color3.fromRGB(200, 200, 200)
				end
			else
				v.Box.Visible = false
				v.Tracer.Visible = false
			end
		else
			v.Box.Visible = false
			v.Tracer.Visible = false
		end
	end
end

